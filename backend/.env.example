# ============================================
#   SMART FINANCE - CẤU HÌNH MÔI TRƯỜNG
# ============================================

# MongoDB Atlas Connection String
# Lấy từ: https://cloud.mongodb.com → Connect → Drivers
MONGO_URI=mongodb+srv://<username>:<password>@cluster0.xxxxx.mongodb.net/smart-finance?retryWrites=true&w=majority

# JWT Secret Key (đặt chuỗi ngẫu nhiên dài ít nhất 32 ký tự)
JWT_SECRET=smart_finance_super_secret_key_2026_change_this

# JWT hết hạn sau bao lâu
JWT_EXPIRES_IN=7d

# Port server chạy
PORT=5000

# Môi trường (development | production)
NODE_ENV=development
